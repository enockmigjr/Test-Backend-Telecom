{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (Process)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(telecom_process_cpu_user_seconds_total[1m]) * 100", "legendFormat": "User CPU %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory RSS (Process)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "telecom_process_resident_memory_bytes", "legendFormat": "RSS" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Event Loop Lag P95",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(telecom_nodejs_eventloop_lag_seconds_bucket[5m])) * 1000", "legendFormat": "Lag" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 1000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Node.js Active Handles",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "telecom_nodejs_active_handles_total", "legendFormat": "Handles" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "title": "Node.js Process Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "Node.js Memory Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "telecom_nodejs_heap_bytes_used_bytes", "legendFormat": "Heap Used" },
        { "expr": "telecom_nodejs_heap_bytes_total_bytes", "legendFormat": "Heap Total" },
        { "expr": "telecom_nodejs_external_memory_bytes", "legendFormat": "External" },
        { "expr": "telecom_process_resident_memory_bytes", "legendFormat": "RSS" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Event Loop Lag & Active Handles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(telecom_nodejs_eventloop_lag_seconds_bucket[5m])) * 1000", "legendFormat": "Event Loop Lag P95 (ms)" },
        { "expr": "telecom_nodejs_active_requests_total", "legendFormat": "Active Requests" },
        { "expr": "telecom_nodejs_active_handles_total", "legendFormat": "Active Handles" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "title": "Infrastructure Services State",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "PostgreSQL Active Database Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "telecom_db_pool_connections", "legendFormat": "Active Connections" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Garbage Collection Count Rate (/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(telecom_nodejs_gc_duration_seconds_count[1m]) * 60", "legendFormat": "GC Cycles/Min" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["telecom", "system", "infrastructure"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Telecom — System & Infra Dashboard",
  "uid": "telecom-system",
  "version": 1,
  "weekStart": ""
}
