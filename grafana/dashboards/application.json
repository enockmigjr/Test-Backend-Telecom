{
  "title": "Telecom API — Application Metrics",
  "uid": "telecom-application",
  "panels": [
    {
      "title": "HTTP Requests Rate (/s)",
      "type": "graph",
      "targets": [
        { "expr": "rate(telecom_http_requests_total[1m])", "legendFormat": "{{method}} {{route}} ({{status_code}})" }
      ]
    },
    {
      "title": "Error Rate 5xx",
      "type": "graph",
      "targets": [
        { "expr": "sum(rate(telecom_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(telecom_http_requests_total[5m])) * 100", "legendFormat": "5xx Error %" }
      ]
    },
    {
      "title": "P95 Latency",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(telecom_http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{method}} {{route}}" }
      ]
    },
    {
      "title": "P50 Latency",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(telecom_http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{method}} {{route}}" }
      ]
    },
    {
      "title": "Tickets Created / min",
      "type": "graph",
      "targets": [
        { "expr": "rate(telecom_tickets_created_total[1m])", "legendFormat": "{{priority}} ({{category}})" }
      ]
    },
    {
      "title": "Active Tickets",
      "type": "stat",
      "targets": [
        { "expr": "telecom_tickets_active" }
      ]
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "targets": [
        { "expr": "telecom_ws_connections" }
      ]
    },
    {
      "title": "Active Users (WebSocket)",
      "type": "stat",
      "targets": [
        { "expr": "telecom_active_users" }
      ]
    },
    {
      "title": "SLA Breaches",
      "type": "stat",
      "targets": [
        { "expr": "rate(telecom_sla_breaches_total[5m])" }
      ]
    },
    {
      "title": "DB Pool Connections",
      "type": "graph",
      "targets": [
        { "expr": "telecom_db_pool_connections" }
      ]
    },
    {
      "title": "Heap Memory Usage %",
      "type": "gauge",
      "targets": [
        { "expr": "telecom_nodejs_heap_bytes_used_bytes / telecom_nodejs_heap_bytes_total_bytes * 100" }
      ]
    },
    {
      "title": "Event Loop Lag (P95)",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(telecom_nodejs_eventloop_lag_seconds_bucket[5m]))" }
      ]
    },
    {
      "title": "API Uptime",
      "type": "stat",
      "targets": [
        { "expr": "up{job=\"telecom-api\"}" }
      ]
    }
  ]
}
