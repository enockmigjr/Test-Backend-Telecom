{
  "title": "Telecom — Business Dashboard",
  "uid": "telecom-business",
  "panels": [
    {
      "title": "Tickets by Status",
      "type": "piechart",
      "targets": [
        { "expr": "sum by (status_code) (telecom_http_requests_total{route=~\"/api/v1/tickets.*\"})", "legendFormat": "{{status_code}}" }
      ]
    },
    {
      "title": "Tickets Created by Priority",
      "type": "barchart",
      "targets": [
        { "expr": "rate(telecom_tickets_created_total[1h])", "legendFormat": "{{priority}} ({{category}})" }
      ]
    },
    {
      "title": "SLA Compliance Rate %",
      "type": "gauge",
      "targets": [
        { "expr": "100 - (rate(telecom_sla_breaches_total[1h]) / rate(telecom_tickets_created_total[1h]) * 100)" }
      ]
    },
    {
      "title": "Error Rate % (Global)",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(telecom_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(telecom_http_requests_total[5m])) * 100" }
      ]
    },
    {
      "title": "Total Tickets (Last 24h)",
      "type": "stat",
      "targets": [
        { "expr": "increase(telecom_tickets_created_total[24h])" }
      ]
    },
    {
      "title": "Active Tickets Trend",
      "type": "graph",
      "targets": [
        { "expr": "telecom_tickets_active", "legendFormat": "Active" }
      ]
    },
    {
      "title": "SLA Breaches (Last 24h)",
      "type": "stat",
      "targets": [
        { "expr": "increase(telecom_sla_breaches_total[24h])" }
      ]
    }
  ]
}
