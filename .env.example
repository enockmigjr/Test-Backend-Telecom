# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ============================================
# Base de données PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=telecom
DATABASE_PASSWORD=telecom_secret
DATABASE_NAME=telecom_tickets
DATABASE_URL=postgresql://telecom:telecom_secret@localhost:5432/telecom_tickets

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@telecom-tickets.local
SMTP_SECURE=false

# ============================================
# Upload de fichiers
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE=10485760

# ============================================
# Throttler (Rate Limiting)
# ============================================
THROTTLE_TTL=900000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=3600000
THROTTLE_AUTH_LIMIT=10

# ============================================
# Application — URLs
# ============================================
LOGIN_URL=http://localhost:3000/login
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug

# ============================================
# OpenTelemetry
# ============================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=telecom-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# ============================================
# Observabilité — Grafana
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_HOST=localhost
GRAFANA_PORT=3001

# ============================================
# Observabilité — Prometheus
# ============================================
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=15

# ============================================
# Observabilité — Loki
# ============================================
LOKI_HOST=loki
LOKI_PORT=3100
LOKI_HTTP_PORT=3100
LOKI_GRPC_PORT=9096
LOKI_RETENTION_DAYS=30

# ============================================
# Observabilité — Tempo
# ============================================
TEMPO_HOST=tempo
TEMPO_PORT=3200
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_HTTP_PORT=4318
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_RETENTION_HOURS=48

# ============================================
# Observabilité — Promtail
# ============================================
PROMTAIL_HTTP_PORT=9080

# ============================================
# Hôtes Docker (pour les configs internes)
# ============================================
API_HOST=api
API_PORT=3000
ALERTMANAGER_HOST=alertmanager
ALERTMANAGER_PORT=9093
NGINX_API_UPSTREAM=api:3000

# ============================================
# Alertmanager
# ============================================
ALERTMANAGER_SMTP_HOST=mailpit
ALERTMANAGER_SMTP_PORT=1025
ALERTMANAGER_SMTP_FROM=alertmanager@telecom-tickets.local
ALERTMANAGER_DEFAULT_EMAIL=ops@telecom-tickets.local
ALERTMANAGER_CRITICAL_EMAIL=oncall@telecom-tickets.local
ALERTMANAGER_WARNING_EMAIL=ops@telecom-tickets.local
# Pour WhatsApp : remplacer par vos propres identifiants CallMeBot
ALERTMANAGER_WHATSAPP_PHONE=22967391224
ALERTMANAGER_WHATSAPP_APIKEY=7499427

# ============================================
# PostgreSQL (Docker Compose)
# ============================================
POSTGRES_USER=telecom
POSTGRES_PASSWORD=telecom_secret
POSTGRES_DB=telecom_tickets
