# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ============================================
# Base de données PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=telecom
DATABASE_PASSWORD=telecom_secret
DATABASE_NAME=telecom_tickets
DATABASE_URL=postgresql://telecom:telecom_secret@localhost:5432/telecom_tickets

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@telecom-tickets.local
SMTP_SECURE=false

# ============================================
# Upload de fichiers
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE=10485760

# ============================================
# Throttler (Rate Limiting)
# ============================================
THROTTLE_TTL=900000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=3600000
THROTTLE_AUTH_LIMIT=10

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug

# ============================================
# OpenTelemetry
# ============================================
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# ============================================
# Observabilité (Prometheus, Loki, Tempo, Grafana)
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION_DAYS=15
LOKI_RETENTION_DAYS=30
TEMPO_RETENTION_HOURS=48
