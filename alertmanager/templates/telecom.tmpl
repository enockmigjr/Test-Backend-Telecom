{{/* Template de notification Telecom — utilisé par Alertmanager */}}

{{ define "telecom.email.html" }}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background: #f5f5f5; }
    .container { max-width: 640px; margin: 20px auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .header { padding: 24px; text-align: center; }
    .header.critical { background: #dc3545; color: #fff; }
    .header.warning { background: #ffc107; color: #333; }
    .header.info { background: #17a2b8; color: #fff; }
    .header h1 { margin: 0; font-size: 20px; }
    .header .count { font-size: 14px; opacity: 0.9; margin-top: 4px; }
    .body { padding: 24px; }
    .alert-card { border: 1px solid #e0e0e0; border-radius: 6px; padding: 16px; margin-bottom: 12px; }
    .alert-card:last-child { margin-bottom: 0; }
    .alert-title { font-weight: 600; font-size: 16px; margin-bottom: 4px; }
    .alert-desc { color: #555; font-size: 14px; margin-bottom: 8px; }
    .alert-labels { display: flex; flex-wrap: wrap; gap: 6px; }
    .label { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
    .label.severity-critical { background: #fde8e8; color: #dc3545; }
    .label.severity-warning { background: #fff8e1; color: #f0ad4e; }
    .footer { padding: 16px 24px; background: #fafafa; border-top: 1px solid #e0e0e0; font-size: 12px; color: #888; text-align: center; }
    .footer a { color: #007bff; text-decoration: none; }
    .meta { font-size: 12px; color: #888; margin-top: 8px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header {{ .GroupLabels.severity }}">
      <h1>🚨 {{ .GroupLabels.alertname }}</h1>
      <div class="count">{{ .Alerts | len }} alerte(s) — Sévérité {{ .GroupLabels.severity | toUpper }}</div>
    </div>
    <div class="body">
      {{ range .Alerts }}
      <div class="alert-card">
        <div class="alert-title">{{ .Annotations.summary }}</div>
        <div class="alert-desc">{{ .Annotations.description }}</div>
        <div class="alert-labels">
          <span class="label severity-{{ .Labels.severity }}">{{ .Labels.severity | toUpper }}</span>
          {{ range $key, $value := .Labels }}
            {{ if and (ne $key "alertname") (ne $key "severity") (ne $key "monitor") }}
            <span class="label">{{ $key }}: {{ $value }}</span>
            {{ end }}
          {{ end }}
        </div>
        <div class="meta">
          Début : {{ .StartsAt.Format "02/01/2006 15:04:05 MST" }}
          {{ if not .EndsAt.IsZero }} | Fin : {{ .EndsAt.Format "02/01/2006 15:04:05 MST" }}{{ end }}
        </div>
      </div>
      {{ end }}
    </div>
    <div class="footer">
      <p>Telecom Ticket Management System — <a href="http://localhost:3001">Grafana</a> | <a href="http://localhost:9090">Prometheus</a></p>
      <p>Pour modifier les règles d'alerte : <code>prometheus/alert.rules.yml</code></p>
    </div>
  </div>
</body>
</html>
{{ end }}

{{ define "telecom.webhook.title" }}{{ template "__subject" . }}{{ end }}

{{ define "telecom.webhook.body" }}
{{ .GroupLabels.alertname }} ({{ .GroupLabels.severity | toUpper }}) — {{ .Alerts | len }} alerte(s)
{{ range .Alerts }}
• {{ .Annotations.summary }}: {{ .Annotations.description }}
  Statut: {{ .Status }} | Début: {{ .StartsAt.Format "02/01/2006 15:04" }}
{{ end }}
{{ end }}
